# Vorlage - scripts/deploy.sh erzeugt die echte .env automatisch mit
# Zufallspasswoertern. Manuell: kopieren nach .env und Werte setzen.
MARIADB_ROOT_PASSWORD=bitte-aendern
MARIADB_DATABASE=appdb
MARIADB_USER=app
MARIADB_PASSWORD=bitte-aendern
GALERA_SST_PASSWORD=bitte-aendern
GALERA_CLUSTER_NAME=mariadb-cluster
# gcache: Puffer fuer inkrementellen Resync (IST) - groesser = laengere
# Ausfaelle ohne Voll-Sync ueberbrueckbar
GALERA_GCACHE_SIZE=512M
INNODB_BUFFER_POOL_SIZE=256M
DB_PORT=3306
STATS_PORT=8404

# Netzwerk - wird von scripts/deploy.sh automatisch gesetzt wenn portolan
# verfuegbar ist. Manuell anpassen falls das Default-Subnet kollidiert.
SUBNET=172.18.0.0/24
GATEWAY=172.18.0.1
IP_HAPROXY=172.18.0.10
IP_MARIADB1=172.18.0.11
IP_MARIADB2=172.18.0.12
IP_GARBD=172.18.0.13
